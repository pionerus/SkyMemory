# =====================================================================
# Cloud server — cmd/server
# =====================================================================
FREEFALL_ENV=development
FREEFALL_HTTP_ADDR=:8000
FREEFALL_DATABASE_URL=postgres://freefall:freefall_dev@localhost:55433/freefall?sslmode=disable
FREEFALL_REDIS_URL=redis://localhost:56379/0

# Generate a real value before going to production: `openssl rand -hex 32`
FREEFALL_SECRET_KEY=dev-secret-not-for-prod

# Optional in dev. In prod, paste DSN from app_settings or Sentry dashboard.
FREEFALL_SENTRY_DSN=

# Used by email templates and webhooks for absolute URLs.
FREEFALL_PUBLIC_BASE_URL=http://localhost:8000

# =====================================================================
# Studio — cmd/studio (local Windows binary)
# =====================================================================
STUDIO_HTTP_ADDR=127.0.0.1:8080
STUDIO_CLOUD_BASE_URL=http://localhost:8000

# Token issued by cloud admin (/admin#license-tokens) and pasted here.
# Without it the studio UI shows "License missing" and pipeline is disabled.
STUDIO_LICENSE_TOKEN=

# Default state.db location: %USERPROFILE%\.freefall-studio\state.db
# Override only if you want it elsewhere.
# STUDIO_STATE_PATH=
